# Maintainer: Janis Hutz <development@janishutz.com>

pkgname=beatsketch-git
pkgver=1.0.0
pkgrel=1
pkgdesc='A Beat Saber Map maker where you PLAY the map you envison in VR'
arch=('any')
url="https://github.com/BeatSketch/launcher"
license=('GPL3')
depends=('python', 'python-pyqt6', 'python-yaml')
makedepends=('git', 'python-build', 'python-installer')
provides=('beatsketch')
conflicts=('beatsketch', 'beatsketch-git')
source=("$pkgname"::git+${url}.git)
sha256sums=('SKIP') # TODO: Add?

pkgver() {
    cd "${pkgname}"

    # TODO: For the non-git pkgbuild, need to use different output
    printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
    cd "${pkgname}"
    python -m build --wheel # --no-isolation (may be needed, testing needed)
}

package() {
    cd "${pkgname}"
    python -m installer --destdir="$pkgdir" dist/*.whl

    _xdg_desktop_name=io.github.beatsketch.$pkgname

    install -Dm 644 "packaging/BeatSketch.desktop" "$pkgdir/usr/share/applications/"

    # TODO: Need to finish
}
